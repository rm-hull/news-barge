<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{{ description or 'News-barge: a clean, ad-free mirror of articles you care about.' }}">

  {% if title %}{% set full_title = (source_site ~ ": " if source_site else "") ~ title %}{% else %}{% set full_title = "News Barge" %}{% endif %}
  <title>{% if title %}{{ full_title }} · {% endif %}News Barge</title>

  <meta property="og:title" content="{{ full_title }}">
  <meta name="twitter:title" content="{{ full_title }}">
  <meta property="og:description" content="{{ description or 'News-barge: a clean, ad-free mirror of articles you care about.' }}">
  <meta property="og:type" content="{% if source_slug %}article{% else %}website{% endif %}">
  <meta name="twitter:card" content="summary_large_image">

  {% if image %}<meta property="og:image" content="{{ image }}">{% endif %}
  <link rel="stylesheet" href="/css/style.css">
  <link rel="alternate" type="application/rss+xml" title="News Barge RSS" href="/feed.xml">
  <link rel="icon" href="https://www.destructuring-bind.org/favicon.ico">
  <script defer src="https://analytics.destructuring-bind.org/script.js" data-website-id="{{ site.umamiWebsiteID }}"></script>
  <script src="/js/share-link.js" defer></script>
</head>
<body>
  <header class="site-header">
    <nav class="nav-inner">
      <a href="/" class="site-name">News Barge</a>
      <div class="nav-links">
        <a href="/">Latest</a>
        <a href="/sites/">Sites</a>
        <a href="/search/">Search</a>
      </div>
    </nav>
  </header>

  <main class="main-content">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p>Scraped for personal use · <a href="https://github.com/{{ site.githubRepo }}">Source</a></p>
  </footer>
</body>
</html>
