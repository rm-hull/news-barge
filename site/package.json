{
  "name": "news-barge-site",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "prestart": "[ -L content ] || ln -s ../content content",
    "prebuild": "[ -L content ] || ln -s ../content content",
    "build": "eleventy --config=eleventy.config.js && pagefind --site _site",
    "start": "eleventy --config=eleventy.config.js --serve",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.6",
    "js-yaml": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.4"
  }
}
