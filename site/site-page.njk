---
layout: base.njk
pagination:
  data: collections.articlesBySitePages
  size: 1
  alias: sitePage
permalink: /sites/{{ sitePage.slug }}/{% if sitePage.pageNumber > 0 %}page/{{ sitePage.pageNumber + 1 }}/{% endif %}
eleventyComputed:
  title: "{{ sitePage.siteName }}"
---
<section class="index-section">
  <h1 class="page-title">{{ sitePage.siteName }}</h1>

  <ul class="article-list">
    {% for article in sitePage.articles %}
    {% include "article-card.njk" %}
    {% endfor %}
  </ul>

  {% if sitePage.previousHref or sitePage.nextHref %}
  <nav class="pagination">
    {% if sitePage.previousHref %}
      <a href="{{ sitePage.previousHref }}" class="page-link">← Newer</a>
    {% endif %}
    {% if sitePage.nextHref %}
      <a href="{{ sitePage.nextHref }}" class="page-link">Older →</a>
    {% endif %}
  </nav>
  {% endif %}
</section>
