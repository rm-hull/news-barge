---
layout: base.njk
pagination:
  data: collections.articlesBySitePages
  size: 1
  alias: sitePage
permalink: /sites/{{ sitePage.slug }}/{% if sitePage.pageNumber > 0 %}page/{{ sitePage.pageNumber + 1 }}/{% endif %}
eleventyComputed:
  title: "{{ sitePage.siteName }}"
---
<section class="index-section">
  <h1 class="page-title">{{ sitePage.siteName }}</h1>

  <ul class="article-list">
    {% for article in sitePage.articles %}
    <li class="article-card">
      <div class="article-card-thumbnail">
        {% if article.data.image %}
        <img src="{{ article.data.image }}" alt="{{ article.data.title }}" loading="lazy">
        {% endif %}
      </div>
      <div class="article-card-content">
        <div class="article-card-meta">
          <a href="/sites/{{ article.data.source_slug }}/" class="site-tag">{{ article.data.source_site }}</a>
          <time datetime="{{ article.data.published }}" title="Scraped at: {{ article.data.scraped_at }}">{{ article.data.published | readableDate }}</time>
        </div>
        <h2 class="article-card-title">
          <a href="{{ article.url }}">{{ article.data.title }}</a>
        </h2>
        {% if article.data.description %}
        <p class="article-card-deck">{{ article.data.description }}</p>
        {% endif %}
      </div>
    </li>
    {% endfor %}
  </ul>

  {% if sitePage.previousHref or sitePage.nextHref %}
  <nav class="pagination">
    {% if sitePage.previousHref %}
      <a href="{{ sitePage.previousHref }}" class="page-link">← Newer</a>
    {% endif %}
    {% if sitePage.nextHref %}
      <a href="{{ sitePage.nextHref }}" class="page-link">Older →</a>
    {% endif %}
  </nav>
  {% endif %}
</section>
