---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>News Barge</title>
    <link>{{ site.url or 'https://example.github.io' }}</link>
    <description>Clean articles, no tracking.</description>
    <atom:link href="{{ site.url or 'https://example.github.io' }}/feed.xml" rel="self" type="application/rss+xml"/>
    {% for article in collections.articles | slice(0, 20) %}
    <item>
      <title>{{ article.data.title | escape }}</title>
      <link>{{ site.url or 'https://example.github.io' }}{{ article.url }}</link>
      <guid>{{ site.url or 'https://example.github.io' }}{{ article.url }}</guid>
      <pubDate>{{ article.data.published }}</pubDate>
      <description>{{ article.data.description | escape }}</description>
      <source url="{{ article.data.source_url }}">{{ article.data.source_site }}</source>
    </item>
    {% endfor %}
  </channel>
</rss>
