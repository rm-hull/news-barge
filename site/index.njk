---
layout: base.njk
title: Latest
pagination:
  data: collections.articles
  size: 30
  alias: articles
  generateIndexFiles: true
permalink: "{% if pagination.pageNumber == 0 %}/{% else %}/page/{{ pagination.pageNumber + 1 }}/{% endif %}"
---
<section class="index-section">
  <h1 class="page-title">Latest articles</h1>

  <ul class="article-list">
    {% for article in articles %}
    <li class="article-card">
      <div class="article-card-thumbnail">
        {% if article.data.image %}
        <img src="{{ article.data.image }}" alt="{{ article.data.title }}" loading="lazy">
        {% endif %}
      </div>
      <div class="article-card-content">
        <div class="article-card-meta">
          <a href="/sites/{{ article.data.source_slug }}/" class="site-tag">{{ article.data.source_site }}</a>
          <time datetime="{{ article.data.published }}" title="Scraped at: {{ article.data.scraped_at }}">{{ article.data.published | readableDate }}</time>
        </div>
        <h2 class="article-card-title">
          <a href="{{ article.url }}">{{ article.data.title }}</a>
        </h2>
        {% if article.data.description %}
        <p class="article-card-deck">{{ article.data.description }}</p>
        {% endif %}
      </div>
    </li>
    {% endfor %}
  </ul>

  {% if pagination.href.previous or pagination.href.next %}
  <nav class="pagination">
    {% if pagination.href.previous %}
      <a href="{{ pagination.href.previous }}" class="page-link">← Newer</a>
    {% endif %}
    {% if pagination.href.next %}
      <a href="{{ pagination.href.next }}" class="page-link">Older →</a>
    {% endif %}
  </nav>
  {% endif %}
</section>